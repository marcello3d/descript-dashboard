# GitHub Personal Access Token (create at https://github.com/settings/tokens)
# Needs "repo" scope for private repos, or just "public_repo" for public only
GITHUB_TOKEN=

# Linear Personal API Key (create at https://linear.app/settings/api)
LINEAR_API_KEY=

# Cursor Background Agents API key (from Cursor Dashboard → Integrations)
CURSOR_API_KEY=
